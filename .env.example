# Django секретный ключ (сгенерируйте свой через python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your-secret-key-here

# Режим отладки (True для разработки, False для продакшена)
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# База данных MySQL
DB_NAME=portal
DB_USER=portal_user
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=3306